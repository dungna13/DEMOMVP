						"body": {
							"mode": "raw",
							"raw": "{\n    \"question\": \"Tôi muốn khiếu nại quyết định thu hồi đất số 123/QĐ-UBND của UBND Hưng Yên vì tôi thấy đền bù không thỏa đáng.\",\n    \"answer\": \"Quyết định thu hồi đất phải căn cứ theo quy định của Luật Đất đai và bảng giá đất mới.\",\n    \"template_type\": \"don_khieu_nai\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/documents/generate-draft",
							"host": [
								"{{base_url}}"
							],
							"path": [
